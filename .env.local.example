# ============================================================
# AI Content Studio - Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI Provider Configuration
# Supports any OpenAI-compatible API (OpenAI, Azure, Groq, Together, Ollama, etc.)
AI_API_KEY=your-api-key
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
AI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe

# Alternative: Use OpenAI directly
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1

# Examples for other providers:
# Groq:
# AI_BASE_URL=https://api.groq.com/openai/v1
# AI_MODEL=llama-3.1-70b-versatile
#
# Together:
# AI_BASE_URL=https://api.together.xyz/v1
# AI_MODEL=meta-llama/Llama-3-70b-chat-hf
#
# Ollama (local):
# AI_BASE_URL=http://localhost:11434/v1
# AI_MODEL=llama3.1
