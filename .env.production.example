NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
INTERNAL_API_SECRET=change-this-long-random-secret
APP_BASE_URL=https://studio.paaair.online
NEXT_PUBLIC_APP_URL=https://studio.paaair.online

AI_API_KEY=your-api-key
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
AI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe

# YouTube OAuth (connect flow TODO)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://studio.paaair.online/api/oauth/youtube/callback

# TikTok OAuth / guarded Content Posting API (connect flow TODO)
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=https://studio.paaair.online/api/oauth/tiktok/callback
TIKTOK_ALLOW_PUBLIC_DIRECT_POST=false

